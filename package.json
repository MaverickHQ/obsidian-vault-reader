{
  "name": "obsidian-vault-reader",
  "version": "0.1.1",
  "private": true,
  "description": "Focused speed reading for notes with in-note highlighting.",
  "license": "MIT",
  "author": "MaverickHQ",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaverickHQ/obsidian-vault-reader.git"
  },
  "bugs": {
    "url": "https://github.com/MaverickHQ/obsidian-vault-reader/issues"
  },
  "homepage": "https://github.com/MaverickHQ/obsidian-vault-reader#readme",
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "plugin",
    "speed-reading",
    "rsvp",
    "vault-reader"
  ],
  "main": "main.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "dev:local": "node scripts/dev-local-vault.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs --production",
    "deploy:local": "node scripts/deploy-local-vault.mjs",
    "build:local": "npm run build && npm run deploy:local",
    "build:release": "npm run check:secrets && npm run check:repo-shape && npm run check:release-artifacts",
    "package:release": "npm run build && node scripts/package-release.mjs",
    "export:clean-tree": "node scripts/export-clean-tree.mjs",
    "verify:clean-tree": "npm run export:clean-tree && node scripts/verify-clean-tree.mjs",
    "verify": "npm run lint && npm run test && npm run build:release",
    "verify:release": "npm run format:check && npm run lint && npm run test && npm run build:release && npm run package:release && npm run test:e2e:release && npm audit --audit-level=high && npm run check:secrets",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:release": "vitest run tests/e2e/release-package-install.test.ts",
    "test:watch": "vitest",
    "check:repo-shape": "bash tests/repo-shape.sh",
    "check:secrets": "bash tests/no-secrets.sh",
    "check:release-artifacts": "bash tests/release-artifacts.sh"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.28.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "jsdom": "^26.0.0",
    "obsidian": "^1.8.7",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
